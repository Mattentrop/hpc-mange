<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hpc_mange.EditClusterPage"
             Title="Gerenciar Cluster"
             BackgroundColor="{StaticResource Superficie}">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Atualizar ou Excluir" TextColor="White" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,20"/>

        <Entry x:Name="EntryNome" Placeholder="Nome do Cluster" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />
        <Entry x:Name="EntryLocalizacao" Placeholder="Localização" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />
        <Entry x:Name="EntryCapacidade" Placeholder="Capacidade de Rede" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />

        <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,20,0,0">
            <Button Grid.Column="0" Text="Atualizar" Clicked="OnAtualizarClicked" BackgroundColor="{StaticResource Acento}" TextColor="{StaticResource Superficie}" FontAttributes="Bold" />
            <Button Grid.Column="1" Text="Excluir" Clicked="OnExcluirClicked" BackgroundColor="#E63946" TextColor="White" FontAttributes="Bold" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>