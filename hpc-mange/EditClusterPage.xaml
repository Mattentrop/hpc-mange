<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hpc_mange.EditClusterPage"
             Title="Gerenciar Cluster"
             BackgroundColor="{StaticResource Superficie}">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label Text="Atualizar ou Excluir" TextColor="White" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,20"/>

            <Entry x:Name="EntryNome" Placeholder="Nome do Cluster" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />
            <Entry x:Name="EntryLocalizacao" Placeholder="Localização" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />
            <Entry x:Name="EntryCapacidade" Placeholder="Capacidade de Rede" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />

            <Label Text="Pesquisador Responsável" TextColor="#A0AEC0" FontSize="12" Margin="0,10,0,0"/>
            <Picker x:Name="PickerPesquisador" ItemDisplayBinding="{Binding Nome}" Title="Selecione um Pesquisador" TitleColor="{StaticResource Neutro}" TextColor="White" BackgroundColor="#111A42" />

            <Label Text="Infraestrutura Associada (Nodos)" TextColor="#2A9D8F" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0"/>
            <CollectionView x:Name="ListaNodos" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#111A42" BorderColor="#4A5568" Padding="10" Margin="0,0,0,5" CornerRadius="8">
                            <Grid ColumnDefinitions="*, Auto">
                                <HorizontalStackLayout Spacing="15" Grid.Column="0">
                                    <Label Text="{Binding Hostname}" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
                                    <Label Text="{Binding ModeloCPU}" TextColor="#A0AEC0" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Button Text="X" Grid.Column="1" TextColor="White" BackgroundColor="#E63946" WidthRequest="35" HeightRequest="35" CornerRadius="17" Padding="0" VerticalOptions="Center" Clicked="OnDeletarNodoClicked" CommandParameter="{Binding .}"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+ Adicionar Nodo Rápido" Clicked="OnAdicionarNodoClicked" BackgroundColor="#2A9D8F" TextColor="White" HeightRequest="40" CornerRadius="8" Margin="0,0,0,10"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                <Button Grid.Column="0" Text="Atualizar" Clicked="OnAtualizarClicked" BackgroundColor="{StaticResource Acento}" TextColor="{StaticResource Superficie}" FontAttributes="Bold" />
                <Button Grid.Column="1" Text="Excluir" Clicked="OnExcluirClicked" BackgroundColor="#E63946" TextColor="White" FontAttributes="Bold" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>