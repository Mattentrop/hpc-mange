<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hpc_mange.GestaoAuxiliarPage"
             Title="Gestão de Recursos"
             BackgroundColor="{StaticResource Superficie}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <Label Text="Pesquisadores" TextColor="{StaticResource Acento}" FontSize="20" FontAttributes="Bold"/>
            <CollectionView x:Name="ListaPesquisadores" HeightRequest="180">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#111A42" BorderColor="#4A5568" Padding="10" Margin="0,0,0,5" CornerRadius="8">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Nome}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Departamento}" TextColor="#A0AEC0" FontSize="12"/>
                                </VerticalStackLayout>
                                <Button Text="X" Grid.Column="1" TextColor="White" BackgroundColor="#E63946" WidthRequest="35" HeightRequest="35" CornerRadius="17" Padding="0" VerticalOptions="Center" Clicked="OnDeletarPesquisadorClicked" CommandParameter="{Binding .}"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Text="+ Novo Pesquisador" Clicked="OnAdicionarPesquisadorClicked" BackgroundColor="#2A9D8F" TextColor="White" CornerRadius="8"/>

            <BoxView HeightRequest="1" Color="#4A5568" Margin="0,10"/>

            <Label Text="Softwares Globais" TextColor="{StaticResource Acento}" FontSize="20" FontAttributes="Bold"/>
            <CollectionView x:Name="ListaSoftwares" HeightRequest="180">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#111A42" BorderColor="#4A5568" Padding="10" Margin="0,0,0,5" CornerRadius="8">
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding NomeModulo}" TextColor="White" FontAttributes="Bold"/>
                                    <Label Text="{Binding Versao}" TextColor="#A0AEC0" FontSize="12"/>
                                </VerticalStackLayout>
                                <Button Text="X" Grid.Column="1" TextColor="White" BackgroundColor="#E63946" WidthRequest="35" HeightRequest="35" CornerRadius="17" Padding="0" VerticalOptions="Center" Clicked="OnDeletarSoftwareClicked" CommandParameter="{Binding .}"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Button Text="+ Novo Software" Clicked="OnAdicionarSoftwareClicked" BackgroundColor="#2A9D8F" TextColor="White" CornerRadius="8"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>