<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hpc_mange.AddNodoPage"
             Title="Adicionar Nodo Completo"
             BackgroundColor="{StaticResource Superficie}">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label Text="Especificações do Nodo" TextColor="White" FontSize="20" FontAttributes="Bold"/>

            <Entry x:Name="EntryHostname" Placeholder="Hostname (ex: node-01)" TextColor="White" BackgroundColor="#111A42"/>
            <Entry x:Name="EntryCPU" Placeholder="Modelo CPU (ex: Intel Xeon Gold)" TextColor="White" BackgroundColor="#111A42"/>
            <Entry x:Name="EntryRAM" Placeholder="Memória RAM em GB (ex: 128)" Keyboard="Numeric" TextColor="White" BackgroundColor="#111A42"/>

            <Label Text="Selecione os Softwares" TextColor="#2A9D8F" FontSize="16" FontAttributes="Bold" Margin="0,10,0,0"/>
            <CollectionView x:Name="ListaSoftwares" SelectionMode="Multiple" HeightRequest="200">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#1A2451" BorderColor="#4A5568" Padding="10" Margin="0,0,0,5" CornerRadius="5">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding NomeModulo}" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
                                <Label Text="{Binding Versao}" TextColor="#A0AEC0" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Salvar Nodo e Softwares" Clicked="OnSalvarClicked" BackgroundColor="{StaticResource Acento}" TextColor="{StaticResource Superficie}" FontAttributes="Bold" HeightRequest="50" Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>