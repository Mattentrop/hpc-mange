<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="hpc_mange.AddClusterPage"
             Title="Novo Cluster"
             BackgroundColor="{StaticResource Superficie}">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="Cadastrar Novo Cluster" TextColor="White" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,20"/>

        <Entry x:Name="EntryNome" Placeholder="Nome do Cluster" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />
        <Entry x:Name="EntryLocalizacao" Placeholder="Localização" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />
        <Entry x:Name="EntryCapacidade" Placeholder="Capacidade de Rede" TextColor="White" PlaceholderColor="{StaticResource Neutro}" />

        <Button Text="Salvar Registro" 
                Clicked="OnSalvarClicked" 
                BackgroundColor="{StaticResource Primaria}" 
                TextColor="White" 
                Margin="0,20,0,0"/>
    </VerticalStackLayout>
</ContentPage>