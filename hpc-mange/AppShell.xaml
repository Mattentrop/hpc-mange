<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:hpc_mange"
       x:Class="hpc_mange.AppShell"
       FlyoutBehavior="Flyout"
       Shell.BackgroundColor="{StaticResource Superficie}"
       Shell.TitleColor="White"
       Shell.ForegroundColor="{StaticResource Acento}">

    <Shell.FlyoutHeader>
        <Grid BackgroundColor="{StaticResource Primaria}" HeightRequest="150" Padding="20">
            <Label Text="HPC Manager" TextColor="White" FontSize="24" FontAttributes="Bold" VerticalOptions="End"/>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Gestão de Clusters">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Relatórios e Exportações">
        <ShellContent ContentTemplate="{DataTemplate local:RelatoriosPage}" />
    </FlyoutItem>

    <MenuItem Text="Sair do Sistema" Clicked="OnLogoutClicked" />

</Shell>